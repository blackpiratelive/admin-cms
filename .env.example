# Environment Configuration for Personal CMS
TURSO_DATABASE_URL="file:local.db"
TURSO_AUTH_TOKEN=""
ADMIN_PASSWORD="admin123"
VERCEL_DEPLOY_HOOK=""
SESSION_SECRET="super-secret-key-at-least-32-characters-long"
STORAGE_PROVIDER="local"

# Cloudinary Direct Upload Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
# Optional: Custom URL prefix or CDN domain (e.g., https://media.myblog.com or https://res.cloudinary.com/my-cloud/image/upload/q_auto)
NEXT_PUBLIC_CLOUDINARY_URL_PREFIX=""
# Cloudinary Admin API Credentials (Required for the Storage dashboard page)
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Cloudflare R2 High-Performance Photo Gallery Upload Configuration
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-api-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-api-secret-access-key"
R2_BUCKET_NAME="gallery"
R2_PUBLIC_DOMAIN="https://gallery-media.yourdomain.com"

